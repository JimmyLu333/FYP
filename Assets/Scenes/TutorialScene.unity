  chatUIManager: {fileID: 1775854853}
  nameText: {fileID: 1504399077}
  choiceButton1: {fileID: 1522171022}
  choiceButton2: {fileID: 450383265}
  choiceButton3: {fileID: 1984091294}
  choiceButtonText1: {fileID: 985442677}
  choiceButtonText2: {fileID: 270634025}
  choiceButtonText3: {fileID: 1079771926}
  playerName: "\u738B\u4ECE\u5FC3"
  npcName: "\u9648\u9ED8"
  autoActorName: PlayerAutoActor
  displayNameForAutoActor: "\u738B\u4ECE\u5FC3"
  npcReplyDelay: 1.2
  scamRateText: {fileID: 584255067}
  currentScamRate: 0
  maxScamRate: 100
  choiceScoreRules:
  - choiceText: "\u5C0F\u9ED8\u554A\uFF01\u597D\u4E45\u6CA1\u8054\u7CFB\u4E86\uFF0C\u542C\u4F60\u5988\u5988\u8BF4\u4F60\u6700\u8FD1\u5728\u627E\u5DE5\u4F5C\uFF1F\u627E\u7684\u600E\u4E48\u6837\u554A\uFF1F"
    scoreGain: 5
  - choiceText: "\u6B63\u597D\u8DDF\u4F60\u8BF4\u4E2A\u4E8B\u2014\u2014\u6211\u6700\u8FD1\u5728\u7F05\u7538\u8FD9\u8FB9\u65C5\u6E38\uFF0C\u5929\u6C14\u597D\uFF0C\u5403\u5F97\u597D\uFF0C\u5929\u5929\u6709\u65B0\u9C9C\u6C34\u679C\uFF0C\u6CF3\u6C60\u8FB9\u8EBA\u7740\uFF0C\u8212\u670D\u5F97\u5F88\u3002"
    scoreGain: 10
  - choiceText: "\u522B\u60F3\u90A3\u4E48\u591A\uFF0C\u5C31\u51FA\u6765\u73A9\u73A9"
    scoreGain: 5
  - choiceText: "\u4F60\u662F\u4E0D\u662F\u4FE1\u4E0D\u8FC7\u8205\u8205\uFF1F\u6211\u8FD8\u80FD\u5BB3\u4F60\u4E0D\u6210\uFF1F"
    scoreGain: -10
  - choiceText: "\u4F60\u77E5\u9053\u5417\uFF0C\u4EBA\u4E0D\u80FD\u603B\u628A\u81EA\u5DF1\u5173\u8D77\u6765\uFF0C\u4F1A\u51FA\u95EE\u9898\u7684\u3002"
    scoreGain: 10
  - choiceText: "\u54CE\uFF0C\u4F60\u8FD8\u662F\u8FD9\u6837\uFF0C\u8DDF\u81EA\u5BB6\u4EBA\u4E5F\u5BA2\u6C14\u3002"
    scoreGain: 10
  - choiceText: "\u4F60\u81EA\u5DF1\u4E70\u4E5F\u884C"
    scoreGain: -5
  - choiceText: "\u4F60\u4EBA\u751F\u5730\u4E0D\u719F\u7684\uFF0C\u6211\u63A5\u4F60\u624D\u653E\u5FC3\u3002"
    scoreGain: 10
  - choiceText: "\u53C8\u4E0D\u9EBB\u70E6\uFF0C\u5230\u65F6\u5019\u770B\u60C5\u51B5\u5427\uFF0C\u6211\u5148\u628A\u9152\u5E97\u5730\u5740\u53D1\u4F60\u3002"
    scoreGain: 5
  - choiceText: "\u591A\u4E0D\u65B9\u4FBF\uFF0C\u4F60\u624B\u673A\u6F2B\u6E38\u5F00\u4E86\u5417\uFF1F\u5230\u4E86\u90A3\u8FB9\u8FD8\u80FD\u7528\u5417\uFF1F"
    scoreGain: -10
  - choiceText: "\u5979\u80FD\u8BF4\u4EC0\u4E48\uFF1F\u5979\u6BD4\u8C01\u90FD\u5FC3\u75BC\u4F60\uFF0C\u770B\u4F60\u8FD9\u6BB5\u65F6\u95F4\u90A3\u4E48\u7D2F\uFF0C\u5634\u4E0A\u4E0D\u8BF4\u800C\u5DF2\u3002"
    scoreGain: 15
  - choiceText: "\u5979\u5012\u662F\u8DDF\u6211\u5FF5\u53E8\u4E86\u51E0\u53E5\uFF0C\u8BF4\u4F60\u6295\u7B80\u5386\u4E0D\u79EF\u6781\uFF0C\u5929\u5929\u5728\u5BB6\u4E5F\u4E0D\u77E5\u9053\u5728\u5E72\u561B\u3002\u6211\u8BF4\u5B69\u5B50\u6709\u5B69\u5B50\u7684\u8282\u594F\uFF0C\u522B\u8001\u50AC\u3002"
    scoreGain: 5
  - choiceText: "\u5979\u5C31\u95EE\u4E86\u4E00\u53E5\u90A3\u8FB9\u5B89\u4E0D\u5B89\u5168\u3002\u8DDF\u7740\u6211\u5F53\u7136\u5B89\u5168\u4E86\uFF0C\u6211\u8FD8\u80FD\u8BA9\u4F60\u51FA\u4E8B\u4E0D\u6210\uFF1F"
    scoreGain: -10
  - choiceText: "\u5BF9\uFF0C\u4F60\u51FA\u6765\u5C31\u80FD\u770B\u5230\u6211\u3002\u6211\u4E3E\u4E2A\u724C\u5B50\u7B49\u4F60\uFF0C\u4E0A\u9762\u5199\u4F60\u540D\u5B57\uFF0C\u591F\u9686\u91CD\u5427\uFF1F\u522B\u5230\u65F6\u5019\u8BA4\u4E0D\u51FA\u8205\u8205\u4E86\u3002"
    scoreGain: 5
