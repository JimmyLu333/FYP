    dialogueText: "\u9AD8\u603B\uFF01\u6211\u77E5...\u77E5\u9053\u3002\r\n"
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u77E5\u9053\u5C31\u597D\u3002\u54B1\u4EEC\u56ED\u533A\u540E\u9762\u90A3\u6761\u6CB3\u91CC\uFF0C\u9CC4\u9C7C\u5DF2\u7ECF\u4E09\u5929\u6CA1\u5403\u4E1C\u897F\u4E86\u3002\u4E0A\u6B21\u90A3\u4E2A\u60F3\u8DD1\u7684\uFF0C\u73B0\u5728\u8FDE\u9AA8\u5934\u90FD\u627E\u4E0D\u7740\u3002"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: "\u9AD8\u603B\uFF0C\u6C42\u60A8\u518D\u7ED9\u6211\u4E00\u6B21\u673A\u4F1A\uFF0C\u8FD9\u4E2A\u6708\u5185\u6211\u4E00\u5B9A\u80FD\u627E\u5230\u4EBA\u3002\r\n"
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u884C\u554A\uFF0C\u4F60\u8981\u673A\u4F1A\u662F\u5427\uFF0C\u55EF...\u4F60\u8001\u5BB6\u662F\u54EA\u7684\u6765\u7740\uFF1F"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: "\u6CB3...\u6CB3\u5357\u3002"
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u6CB3\u5357...\u4F60\u6709\u4EC0\u4E48\u4EB2\u621A\u5417\uFF1F\u4F60\u5E94\u8BE5\u77E5\u9053\uFF0C\u54B1\u4EEC\u8FD9\u884C\uFF0C\u6700\u597D\u9A97\u7684\u5C31\u662F\u719F\u4EBA\u3002"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: "\u9AD8\u603B\uFF0C\u6C42\u60A8\u518D\u7ED9\u6211\u4E00\u6B21\u673A\u4F1A\u5427\uFF01\u6211\u518D\u53BB\u627E\u627E\u4E00\u5B9A\u6709\u522B\u4EBA..."
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u8001\u738B\u554A\uFF0C\u6211\u662F\u4E0D\u662F\u7ED9\u4F60\u8138\u4E86\uFF1F\u8F6E\u5230\u4F60\u8DDF\u6211\u8BB2\u6761\u4EF6\uFF1F\u6211\u770B\u4F60\u662F\u8001\u5458\u5DE5\u7684\u4EFD\u4E0A\u73B0\u5728\u7ED9\u4F60\u6700\u540E\u4E24\u6761\u8DEF\u3002\u4E00\uFF0C\u660E\u5929\u5929\u9ED1\u4E4B\u524D\uFF0C\u9A97\u5230\u81F3\u5C11\u4E24\u4E07\u3002\u4E8C\uFF0C\u544A\u8BC9\u6211\u4F60\u5BB6\u4EBA\u7684\u8054\u7CFB\u65B9\u5F0F\uFF0C\u6211\u8BA9\u522B\u4EBA\u5E2E\u4F60\u505A\u3002"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: "\u9AD8\u603B...\u6C42\u6C42\u60A8\u4E86...\u6211\uFF0C\u6211\u5176\u5B9E\u8FD8\u6709\u4E2A\u4EB2\u621A
      \uFF0C\u4F46\u4ED6\u8FD8\u5C0F...."
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u8FD9\u5C31\u5BF9\u4E86\u561B\u3002\u8001\u738B\uFF0C\u6211\u5C31\u77E5\u9053\u4F60\u6CA1\u8BA9\u6211\u5931\u671B\u3002\u4F60\u6700\u597D\u7ED9\u6211\u628A\u4ED6\u5E26\u8FC7\u6765\uFF0C\u8FD9\u6837\u4F60\u548C\u4ED6\u4E5F\u6B63\u597D\u6709\u4E2A\u7167\u5E94\u561B\u3002
      \r"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: "\u9AD8\u603B\uFF0C\u4ED6...\u4ED6\u53EA\u662F\u4E2A\u521A\u6BD5\u4E1A\u7684\u5B69\u5B50\uFF0C\u4EC0\u4E48\u90FD\u4E0D\u61C2\u3002\u6211\u80FD\u4E0D\u80FD\u5C31..."
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u5C31\u4EC0\u4E48\uFF1F\u5C31\u9A97\u70B9\u94B1\uFF1F\u8001\u738B\u554A\uFF0C\u4F60\u8FD9\u5C31\u4E0D\u61C2\u4E86\u3002\u9A97\u94B1\u662F\u4E00\u6B21\u6027\u7684\uFF0C\u4EBA\u6765\u4E86\uFF0C\u90A3\u53EF\u662F\u957F\u671F\u996D\u7968\u554A\u3002\u800C\u4E14\u4F60\u4F84\u5B50\u6765\u4E86\uFF0C\u4F60\u4FE9\u6709\u4E2A\u7167\u5E94\u3002"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: ......
  - characterName: "\u9AD8\u5584"
    dialogueText: "\u884C\u4E86\uFF0C\u53BB\u5427\u3002\u4E0B\u5468\u4E00\u4E4B\u524D\uFF0C\u6211\u8981\u770B\u5230\u4ED6\u5728\u8FD9\u3002\u6216\u8005...\u4F60\u77E5\u9053\u8BE5\u53BB\u54EA\u3002\u7B49\u4ED6\u6765\u4E86\u4F60\u591A\u5E26\u5E26\u4ED6\uFF0C\u7B49\u4ED6\u4E0A\u624B\u4E86\uFF0C\u4F60\u4E5F\u80FD\u8F7B\u677E\u70B9\u3002"
  - characterName: "\u738B\u4ECE\u5FC3"
    dialogueText: "...\u77E5\u9053\u4E86\u9AD8\u603B"
  typingSpeed: 0.05
  nameTMP: {fileID: 562167671}
  contentTMP: {fileID: 323027064}
