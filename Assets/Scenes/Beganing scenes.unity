  - characterName: "\u9AD8\u5584"
    dialogueText: "\u5C3D\u529B\u4E86\uFF1F\u4E0A\u4E2A\u6708\u8FD8\u884C\uFF0C\u67093\u4E07\u3002\u4F46\u8FD9\u4E2A\u6708\uFF0C\u5230\u73B0\u5728\u624D8000\u3002\u4F60\u7BA1\u8FD9\u4E2A\u53EB\u5C3D\u529B\u4E86\uFF1F\u4F60\u4E5F\u662F\u8001\u5458\u5DE5\u4E86\uFF0C\u4F60\u77E5\u9053\u6D88\u6781\u6020\u5DE5\u7684\u4E0B\u573A\u7684\u5427\u3002"
